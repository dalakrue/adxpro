def _detect_lunch_regime_changes(d, horizon=24):
    """Fast EURUSD-aligned regime detector + simple regime duration forecast.

    Additive helper only: it reads the already-normalized Data Visualization
    frame and does not mutate source data or trigger heavy metric engines.
    """
    import pandas as pd
    import numpy as np
    if d is None or not isinstance(d, pd.DataFrame) or d.empty or "close" not in d.columns:
        return {"ok": False, "message": "No clean OHLC data."}, pd.DataFrame()
    x = d.copy()
    if "time" not in x.columns:
        x["time"] = pd.date_range(end=pd.Timestamp.now(), periods=len(x), freq="h")
    x["time"] = pd.to_datetime(x["time"], errors="coerce")
    x["close"] = pd.to_numeric(x["close"], errors="coerce")
    if "open" in x.columns:
        x["open"] = pd.to_numeric(x["open"], errors="coerce")
    else:
        x["open"] = x["close"].shift(1).fillna(x["close"])
    x = x.dropna(subset=["time", "close"]).sort_values("time").reset_index(drop=True)
    if len(x) < 20:
        return {"ok": False, "message": "Need at least 20 candles for regime analysis."}, pd.DataFrame()

    close = x["close"].astype("float64")
    ret = close.pct_change().replace([np.inf, -np.inf], np.nan).fillna(0.0)
    trend = x["trend_gap_pct"] if "trend_gap_pct" in x.columns else close.ewm(span=12, adjust=False).mean().sub(close.ewm(span=48, adjust=False).mean()).div(close.replace(0, np.nan)).mul(100).fillna(0)
    vol = x["volatility_pct"] if "volatility_pct" in x.columns else ret.rolling(36, min_periods=4).std().mul(100).fillna(0)
    mom = ret.rolling(12, min_periods=3).mean().fillna(0)
    vol_med = float(vol.rolling(144, min_periods=20).median().iloc[-1]) if len(vol) >= 20 else float(vol.median())
    vol_hi = float(vol.rolling(144, min_periods=20).quantile(.70).iloc[-1]) if len(vol) >= 20 else float(vol.quantile(.70))

    direction = np.where((trend > 0) & (mom >= 0), "BULL", np.where((trend < 0) & (mom <= 0), "BEAR", "RANGE"))
    energy = np.where(vol >= max(vol_hi, vol_med * 1.2), "HIGH_VOL", np.where(vol <= max(vol_med * .72, 1e-9), "LOW_VOL", "NORMAL_VOL"))
    x["regime"] = pd.Series(direction, index=x.index).astype(str) + "_" + pd.Series(energy, index=x.index).astype(str)
    # Smooth one-candle noise so EURUSD H1 does not flip regime too easily.
    # Pandas rolling().agg/apply only accepts numeric windows in many versions.
    # Keep this string-safe so Streamlit never raises: DataError: No numeric types to aggregate.
    regimes = x["regime"].astype(str).tolist()
    smooth = []
    for i in range(len(regimes)):
        window = regimes[max(0, i - 2):i + 1]
        vc = pd.Series(window, dtype="object").value_counts()
        smooth.append(str(vc.index[0]) if not vc.empty else str(regimes[i]))
    x["regime_smooth"] = pd.Series(smooth, index=x.index, dtype="object")
    x["regime_changed"] = x["regime_smooth"].ne(x["regime_smooth"].shift(1))

    changes = x.loc[x["regime_changed"]].copy()
    if changes.empty:
        changes = x.head(1).copy()
    rows = []
    idxs = list(changes.index)
    for n, idx in enumerate(idxs):
        end_idx = (idxs[n + 1] - 1) if n + 1 < len(idxs) else len(x) - 1
        seg = x.loc[idx:end_idx]
        start_time = pd.Timestamp(x.loc[idx, "time"])
        end_time = pd.Timestamp(x.loc[end_idx, "time"])
        duration_days = max((end_time - start_time).total_seconds() / 86400.0, 0.0)
        rows.append({
            "Regime Change Day": start_time.strftime("%Y-%m-%d"),
            "Change Time": start_time.strftime("%Y-%m-%d %H:%M"),
            "Regime": str(x.loc[idx, "regime_smooth"]),
            "Open": round(float(seg["open"].iloc[0]), 5),
            "Close": round(float(seg["close"].iloc[-1]), 5),
            "Bars": int(len(seg)),
            "Duration Days": round(duration_days, 2),
            "Return %": round((float(seg["close"].iloc[-1]) / max(float(seg["open"].iloc[0]), 1e-12) - 1.0) * 100, 4),
            "Avg Vol %": round(float(vol.loc[seg.index].mean()), 5),
            "Avg Trend Gap %": round(float(trend.loc[seg.index].mean()), 5),
            "Regime Score /10": round(float(max(0, min(10, 5 + abs(float(trend.loc[seg.index].mean())) * 0.35 + float(vol.loc[seg.index].mean()) * 0.55 + min(len(seg) / 48.0, 2.0)))), 2),
        })
    hist = pd.DataFrame(rows)
    durations = pd.to_numeric(hist["Duration Days"], errors="coerce").dropna()
    completed = durations.iloc[:-1] if len(durations) > 1 else durations
    median_days = float(completed.median()) if len(completed) else max(float(horizon) / 24.0, 1.0)
    last_row = hist.iloc[-1].to_dict()
    last_change_time = pd.to_datetime(last_row.get("Change Time"), errors="coerce")
    now_time = pd.Timestamp(x["time"].iloc[-1])
    elapsed_days = max((now_time - last_change_time).total_seconds() / 86400.0, 0.0) if pd.notna(last_change_time) else 0.0
    remaining_days = max(median_days - elapsed_days, 0.0)
    predicted_change_time = now_time + pd.Timedelta(days=remaining_days)
    current_regime = str(last_row.get("Regime", "UNKNOWN"))
    stability = int(max(0, min(100, 100 - abs(float(trend.iloc[-1])) * 5 - float(vol.iloc[-1]) * 18 + min(elapsed_days / max(median_days, 1e-9), 1) * 20)))
    current_score_10 = round(float(max(0, min(10, 5 + abs(float(trend.iloc[-1])) * 0.35 + float(vol.iloc[-1]) * 0.55 + min(elapsed_days / max(median_days, 1e-9), 1.0) * 2.0))), 2)
    summary = {
        "ok": True,
        "current_regime": current_regime,
        "last_regime_change_day": str(last_row.get("Regime Change Day", "")),
        "last_regime_change_time": str(last_row.get("Change Time", "")),
        "days_since_last_change": round(float(elapsed_days), 2),
        "estimated_days_remaining": round(float(remaining_days), 2),
        "estimated_next_change_day": predicted_change_time.strftime("%Y-%m-%d"),
        "estimated_next_change_time": predicted_change_time.strftime("%Y-%m-%d %H:%M"),
        "median_regime_days": round(float(median_days), 2),
        "regime_stability_pct": stability,
        "regime_score_10": current_score_10,
        "history_rows": int(len(hist)),
    }
    return summary, hist.tail(80).reset_index(drop=True)

def _clean_lunch_visual_df(limit=1500):
    """Normalize shared Lunch/Home data for Data Visualization without changing original source data."""
    import pandas as pd
    import numpy as np
    import streamlit as st
    df = st.session_state.get("last_df")
    if not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame()
    limit = int(max(80, min(int(limit or 1500), 5000)))
    d = _compact_ohlc_tail(df, rows=limit)
    if d.empty or "close" not in d.columns:
        return pd.DataFrame()
    if "time" not in d.columns:
        d["time"] = pd.date_range(end=pd.Timestamp.now(), periods=len(d), freq="min")
    d["time"] = pd.to_datetime(d["time"], errors="coerce")
    for c in ["open", "high", "low", "close", "volume"]:
        if c in d.columns:
            d[c] = pd.to_numeric(d[c], errors="coerce")
    d = d.dropna(subset=["time", "close"]).sort_values("time").drop_duplicates("time", keep="last").tail(limit).reset_index(drop=True)
    if d.empty:
        return d
    close = d["close"].astype("float64")
    d["return_pct"] = close.pct_change().mul(100).replace([np.inf, -np.inf], np.nan).fillna(0)
    d["ma_fast"] = close.ewm(span=12, adjust=False, min_periods=2).mean()
    d["ma_slow"] = close.ewm(span=48, adjust=False, min_periods=4).mean()
    d["ma_trend"] = close.ewm(span=144, adjust=False, min_periods=8).mean()
    d["volatility_pct"] = d["return_pct"].rolling(36, min_periods=4).std().fillna(0)
    if {"high", "low"}.issubset(d.columns):
        d["range_pct"] = ((d["high"] - d["low"]) / close.replace(0, np.nan) * 100).replace([np.inf, -np.inf], np.nan).fillna(0)
    else:
        d["range_pct"] = d["return_pct"].abs()
    trend_gap = ((d["ma_fast"].astype("float64") - d["ma_slow"].astype("float64")) / close.replace(0, np.nan) * 100).replace([np.inf, -np.inf], np.nan).fillna(0)
    d["trend_gap_pct"] = trend_gap
    mom_fast = d["return_pct"].rolling(8, min_periods=2).mean().fillna(0)
    mom_slow = d["return_pct"].rolling(34, min_periods=4).mean().fillna(0)
    range_pressure = d["range_pct"].rolling(20, min_periods=4).mean().fillna(0)
    score = 50 + mom_fast * 210 + mom_slow * 125 + trend_gap * 18 - d["volatility_pct"] * 14 + range_pressure * 2
    d["ml_score"] = score.clip(0, 100).fillna(50)
    d["ml_bias"] = np.where(d["ml_score"] >= 58, "BUY", np.where(d["ml_score"] <= 42, "SELL", "WAIT"))
    d["volume_z"] = 0.0
    if "volume" in d.columns:
        vol_mean = d["volume"].rolling(48, min_periods=8).mean()
        vol_std = d["volume"].rolling(48, min_periods=8).std().replace(0, np.nan)
        d["volume_z"] = ((d["volume"] - vol_mean) / vol_std).replace([np.inf, -np.inf], np.nan).fillna(0).clip(-5, 5)
    med = float(d["volatility_pct"].median()) if len(d) else 0.0
    q75 = float(d["volatility_pct"].quantile(.75)) if len(d) >= 20 else med
    q25 = float(d["volatility_pct"].quantile(.25)) if len(d) >= 20 else med
    d["risk_bucket"] = np.where(d["volatility_pct"] >= q75, "HIGH VOL", np.where(d["volatility_pct"] <= q25, "LOW VOL", "NORMAL"))
    d["session_hour"] = d["time"].dt.hour.astype("int16")
    return d


def _render_lunch_advanced_powerbi_ml_projection(d, horizon=24):
    """Additive second Power BI + ML projection block. It does not replace the original visualization block."""
    import json
    import pandas as pd
    import streamlit as st
    try:
        import plotly.graph_objects as go
        from plotly.subplots import make_subplots
    except Exception as exc:
        st.warning(f"Plotly is not available for advanced Power BI projection: {exc}")
        return
    if d is None or d.empty or len(d) < 20:
        st.info("Advanced Power BI + ML projection needs at least 20 clean candles.")
        return

    st.markdown("### 🧠 Advanced Power BI Price + ML Projection")
    st.caption("Upgraded single visualization for price, ML, regime detection, regime score, and next-change forecast.")
    horizon = int(max(6, min(int(horizon or 24), 96)))
    last = float(d["close"].iloc[-1])
    ret = d["close"].pct_change().replace([float("inf"), float("-inf")], pd.NA).dropna()
    momentum_short = float(ret.tail(12).mean() if len(ret) else 0.0)
    momentum_mid = float(ret.tail(48).mean() if len(ret) else 0.0)
    vol = float(ret.tail(96).std() if len(ret) >= 5 else 0.0)
    ml_last = float(d["ml_score"].iloc[-1]) if "ml_score" in d.columns else 50.0
    trend_gap = float(d["trend_gap_pct"].iloc[-1]) if "trend_gap_pct" in d.columns else 0.0
    volume_z = float(d["volume_z"].iloc[-1]) if "volume_z" in d.columns else 0.0

    # Advanced light ensemble: short momentum + medium momentum + ML score tilt + trend + volume confirmation.
    ml_tilt = (ml_last - 50.0) / 9500.0
    trend_tilt = max(-0.002, min(0.002, trend_gap / 6500.0))
    volume_tilt = max(-0.0012, min(0.0012, volume_z / 18000.0))
    drift = max(-0.006, min(0.006, momentum_short * .55 + momentum_mid * .30 + ml_tilt + trend_tilt + volume_tilt))
    steps = pd.Series(range(1, horizon + 1), dtype="float64")
    future_time = pd.date_range(d["time"].iloc[-1], periods=horizon + 1, freq="h")[1:]
    projection = last * (1 + drift * steps)
    band = max(vol, 1e-6) * (steps ** 0.5) * 1.35
    upper = projection * (1 + band)
    lower = projection * (1 - band)
    direction = "BUY / UP" if float(projection.iloc[-1]) > last else "SELL / DOWN" if float(projection.iloc[-1]) < last else "WAIT / SIDEWAYS"
    confidence = int(max(0, min(100, 50 + abs(drift) * 9500 - vol * 5200 + abs(ml_last - 50) * .42 + min(abs(volume_z), 3) * 2)))

    regime_summary, regime_history = _detect_lunch_regime_changes(d, horizon=horizon)

    k1, k2, k3, k4 = st.columns(4)
    k1.metric("Current Price", f"{last:.5f}")
    k2.metric("ML Projection", direction)
    k3.metric("Projected Price", f"{float(projection.iloc[-1]):.5f}")
    k4.metric("Confidence", f"{confidence}%")

    r1, r2, r3, r4 = st.columns(4)
    if regime_summary.get("ok"):
        r1.metric("Current Regime", regime_summary.get("current_regime", "UNKNOWN"))
        r2.metric("Last Regime Change", regime_summary.get("last_regime_change_day", "-"), f"{regime_summary.get('days_since_last_change', 0)} days ago")
        r3.metric("Est. Days Remaining", f"{regime_summary.get('estimated_days_remaining', 0)}", regime_summary.get("estimated_next_change_day", "-"))
        r4.metric("Regime Score /10", f"{regime_summary.get('regime_score_10', 0)}/10", f"Stability {regime_summary.get('regime_stability_pct', 0)}%")
    else:
        r1.metric("Current Regime", "WAIT")
        r2.metric("Last Regime Change", "N/A")
        r3.metric("Est. Days Remaining", "N/A")
        r4.metric("Regime Score /10", "N/A")

    p1, p2, p3, p4 = st.columns(4)
    p1.metric("Last Open", f"{float(d['open'].iloc[-1]):.5f}" if "open" in d.columns else "N/A")
    p2.metric("Last Close", f"{last:.5f}")
    p3.metric("Predicted Close", f"{float(projection.iloc[-1]):.5f}")
    p4.metric("Predicted Open", f"{float(projection.iloc[0]):.5f}")

    show = d.tail(min(len(d), 900)).copy()
    fig = make_subplots(rows=3, cols=1, shared_xaxes=True, vertical_spacing=.045, row_heights=[.58, .22, .20])
    fig.add_trace(go.Scatter(x=show["time"], y=show["close"], name="Actual Close", mode="lines"), row=1, col=1)
    if "ma_fast" in show.columns:
        fig.add_trace(go.Scatter(x=show["time"], y=show["ma_fast"], name="Fast MA", mode="lines"), row=1, col=1)
    if "ma_slow" in show.columns:
        fig.add_trace(go.Scatter(x=show["time"], y=show["ma_slow"], name="Slow MA", mode="lines"), row=1, col=1)
    if "ma_trend" in show.columns:
        fig.add_trace(go.Scatter(x=show["time"], y=show["ma_trend"], name="Trend MA", mode="lines"), row=1, col=1)
    fig.add_trace(go.Scatter(x=future_time, y=projection, name="Advanced ML Projection", mode="lines"), row=1, col=1)
    fig.add_trace(go.Scatter(x=future_time, y=upper, name="Projection High", mode="lines", line=dict(dash="dot")), row=1, col=1)
    fig.add_trace(go.Scatter(x=future_time, y=lower, name="Projection Low", mode="lines", line=dict(dash="dot"), fill="tonexty"), row=1, col=1)
    fig.add_trace(go.Bar(x=show["time"], y=show.get("return_pct", 0), name="Return %"), row=2, col=1)
    fig.add_trace(go.Scatter(x=show["time"], y=show.get("ml_score", 50), name="ML Score", mode="lines"), row=3, col=1)
    fig.add_trace(go.Scatter(x=show["time"], y=show.get("volatility_pct", 0), name="Volatility %", mode="lines"), row=3, col=1)
    fig.update_layout(height=720, template="plotly_white", margin=dict(l=8, r=8, t=34, b=8), legend=dict(orientation="h"), title="Advanced Power BI-style Price + Risk + ML Projection")
    st.plotly_chart(fig, use_container_width=True)

    table_cols = [c for c in ["time", "open", "high", "low", "close", "return_pct", "range_pct", "volatility_pct", "trend_gap_pct", "volume_z", "risk_bucket", "ml_score", "ml_bias"] if c in d.columns]
    table = d.tail(120)[table_cols].copy()
    # Add compact forward Open/Close predictor fields for the Lunch export/table.
    table["predictor_next_open"] = float(projection.iloc[0])
    table["predictor_horizon_close"] = float(projection.iloc[-1])
    table["predictor_high"] = float(upper.iloc[-1])
    table["predictor_low"] = float(lower.iloc[-1])
    table["regime_score_10"] = regime_summary.get("regime_score_10") if regime_summary.get("ok") else None
    table["estimated_regime_change_day"] = regime_summary.get("estimated_next_change_day") if regime_summary.get("ok") else None
    st.session_state["lunch_prediction_export"] = {
        "direction": direction,
        "current_price": round(last, 5),
        "projected_horizon": int(horizon),
        "projected_price": round(float(projection.iloc[-1]), 5),
        "projection_high": round(float(upper.iloc[-1]), 5),
        "projection_low": round(float(lower.iloc[-1]), 5),
        "confidence_pct": confidence,
        "ml_score": round(ml_last, 2),
        "ml_bias": str(d["ml_bias"].iloc[-1]) if "ml_bias" in d.columns else "N/A",
        "risk_bucket": str(d["risk_bucket"].iloc[-1]) if "risk_bucket" in d.columns else "N/A",
        "trend_gap_pct": round(trend_gap, 4),
        "volume_z": round(volume_z, 4),
        "rows_used": int(len(d)),
        "weekday": pd.Timestamp.now().strftime("%A"),
        "regime": regime_summary,
    }
    st.session_state["lunch_regime_history"] = regime_history
    st.session_state["lunch_visualization_export"] = table.to_csv(index=False)
    with st.expander("📋 Open / Close — Advanced Power BI table + regime history + copy", expanded=False):
        st.dataframe(table, use_container_width=True, hide_index=True)
        if regime_summary.get("ok"):
            m1, m2 = st.columns(2)
            m1.metric("Last Regime Change Day", regime_summary.get("last_regime_change_day", "-"), f"{regime_summary.get('days_since_last_change', 0)} days ago")
            m2.metric("Estimated Regime Last Days", f"{regime_summary.get('estimated_days_remaining', 0)} days", regime_summary.get("estimated_next_change_day", "-"))
            m3, m4 = st.columns(2)
            m3.metric("Regime Score", f"{regime_summary.get('regime_score_10', 0)}/10")
            m4.metric("Current Regime", regime_summary.get("current_regime", "UNKNOWN"))
        with st.expander("📆 Open / Close — Regime change history with Open and Close", expanded=False):
            if regime_history is not None and not regime_history.empty:
                st.dataframe(regime_history, use_container_width=True, hide_index=True)
            else:
                st.info("No regime history is available yet.")
        regime_csv = regime_history.to_csv(index=False) if regime_history is not None and not regime_history.empty else ""
        payload = "LUNCH ADVANCED POWER BI + ML PROJECTION EXPORT\n" + json.dumps(st.session_state["lunch_prediction_export"], indent=2, default=str) + "\n\nLATEST BI TABLE\n" + table.to_csv(index=False) + "\n\nREGIME CHANGE HISTORY\n" + regime_csv
        try:
            from core.pro_terminal_uiux import render_mobile_copy_button
            render_mobile_copy_button("Copy Advanced Power BI + ML Projection", payload, "lunch_advanced_powerbi_ml_copy")
        except Exception:
            pass
        st.text_area("Fallback advanced BI export", payload, height=220, key="lunch_advanced_bi_export_fallback")


